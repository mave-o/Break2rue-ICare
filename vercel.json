{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "server.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "public/hospital_db.json",
          "data/hospital_db.json",
          "data/triage.json",
          "data/specialties.json"
        ]
      }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "server.ts" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
